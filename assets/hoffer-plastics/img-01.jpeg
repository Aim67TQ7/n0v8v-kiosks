        <script>
            document.addEventListener('DOMContentLoaded', function() {

                const section = '.section_7';
                const sliderEl = document.querySelector(section + ' .service_list_slider__service_list > .splide');

                let serviceListSlider = null;

                if (sliderEl && !sliderEl.classList.contains('is-mounted')) {
                    sliderEl.classList.add('is-mounted'); 

                    serviceListSlider = new Splide(sliderEl, {
                        type: "slide",
                        arrows: true,
                        drag: false,
                        pagination: false,
                        slideFocus: 1,
                        updateOnMove: true,
                        gap: 3,
                        perPage: 4,
                        perMove: 1,
                        breakpoints: {
                            2048: {
                                perPage: 3
                            },
                            1199: {
                                perPage: 2
                            },
                            991: {
                                destroy: true
                            }
                        }
                    });

                    serviceListSlider.on( 'move', function (index) {
                        document.querySelector(section + ' .tab_item[data-slide="'+index+'"]').click();
                    });

                    serviceListSlider.mount();
                }

                const tabs = document.querySelectorAll(section + ' .tab_item');
                if (tabs.length > 0) {
                    tabs[0].classList.add('active');
                }

                const slides = sliderEl.querySelectorAll('.splide__slide');
                if (slides.length > 0) {
                    slides[0].classList.add('is-active');
                }


                tabs.forEach(tab => {
                    tab.addEventListener('click', function() {
                        const index = parseInt(this.getAttribute('data-slide'));
                        const slides = sliderEl.querySelectorAll('.splide__slide');

                        if (serviceListSlider) {
                            serviceListSlider.go(index);
                        }

                        slides.forEach((s, i) => {
                            s.classList.toggle('is-active', i === index);
                        });

                        tabs.forEach(t => t.classList.remove('active'));
                        this.classList.add('active');
                    });
                });



            });
        </script>
    </div>
		</section>
